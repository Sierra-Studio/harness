# --- Provider (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-
HARNESS_MODEL=deepseek/deepseek-v4-pro

# --- Database ---
# When unset, the harness uses the in-memory repository (good for dev/demo).
DATABASE_URL=postgresql://harness:harness@localhost:5432/harness

# --- Remote MCP servers (auto-connected by `harness chat`) ---
# Comma-separated "name=url".
# Auth per server: MCP_<NAME>_TOKEN (static bearer) OR MCP_<NAME>_OAUTH=1 (browser login).
MCP_HTTP_SERVERS=fellow=https://fellow.app/mcp
MCP_FELLOW_OAUTH=1
# MCP_FELLOW_TOKEN=        # alternative to OAuth: a static bearer token

# --- Embeddings (for skills semantic search) ---
# OpenAI-compatible endpoint. When EMBEDDING_API_KEY is unset, a deterministic
# LOCAL fallback is used (non-semantic, dev only).
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Budgets / loop controls ---
TOKEN_BUDGET_PER_SESSION=500000   # hard ceiling; loop stops & returns partial. 0 = unlimited
RESPONSE_RESERVE_TOKENS=4000      # tokens reserved for the model's reply
MAX_STEPS=25                      # max loop iterations per turn
CHECKPOINT_EVERY_USER_TURNS=20    # subject classification cadence
SKILL_INDUCTION_EVERY_SESSIONS=10 # auto skill induction cadence
SUMMARY_KEEP_RATIO=0.10           # fraction of recent messages kept verbatim

# --- Soul (persona) & Bash tool ---
HARNESS_SOUL_PATH=                 # path to a SOUL.md; empty => ./SOUL.md, else default identity
BASH_TIMEOUT=60                   # per-command timeout (seconds)
BASH_MAX_OUTPUT=10000             # chars before head/tail elision
