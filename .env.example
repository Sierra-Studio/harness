# --- Provider (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-
HARNESS_MODEL=deepseek/deepseek-v4-pro

# --- Provider (Azure AI Foundry) ---
# Setting AZURE_AI_ENDPOINT selects the Azure provider (takes precedence over
# OpenRouter). HARNESS_MODEL is used as the Azure *deployment* name.
# AZURE_AI_ENDPOINT=https://<resource>.services.ai.azure.com
# AZURE_AI_API_KEY=                 # leave empty to use Entra ID / managed identity
# AZURE_AI_API_VERSION=preview      # api-version for the /openai/v1 route
# AZURE_CLIENT_ID=                  # user-assigned managed identity client id (optional)
# Managed identity (no stored secret) needs the azure extra: pip install 'harness[azure]'.
# Azure has no /models endpoint to auto-detect context size (unlike OpenRouter),
# so set this to your deployment's real context window — otherwise it silently
# falls back to 128000, which under-budgets larger-context models.
# DEFAULT_CONTEXT_WINDOW=128000

# --- Provider (Google Vertex AI) ---
# Setting GCP_VERTEX_PROJECT selects the Vertex provider (after Azure). Uses the
# OpenAI-compatible endpoint; HARNESS_MODEL is a Vertex model id, e.g.
# google/gemini-2.0-flash. Auth = Application Default Credentials (needs the
# vertex extra: pip install 'harness[vertex]'). Set GOOGLE_APPLICATION_CREDENTIALS
# to a service-account key, or run `gcloud auth application-default login`.
# GCP_VERTEX_PROJECT=my-gcp-project
# GCP_VERTEX_LOCATION=us-central1

# --- Provider (AWS Bedrock) ---
# Setting AWS_BEDROCK_REGION selects the Bedrock provider (after Vertex). Uses the
# Converse API; HARNESS_MODEL is a Bedrock model or inference-profile id, e.g.
# us.anthropic.claude-3-5-sonnet-20241022-v2:0. Auth = the standard boto3 chain
# (env vars / shared config / IAM role). Needs the bedrock extra:
# pip install 'harness[bedrock]'. NOTE: plain AWS_REGION does NOT auto-select
# Bedrock — you must set AWS_BEDROCK_REGION explicitly.
# AWS_BEDROCK_REGION=us-east-1

# --- Database ---
# When unset, the harness uses the in-memory repository (good for dev/demo).
# IMPORTANT (ephemeral / Azure Container Apps): you MUST set DATABASE_URL to a
# managed Postgres (e.g. Azure Database for PostgreSQL Flexible Server) — an
# unset value silently falls back to in-memory and loses ALL state on every
# restart or scale event. Bootstrap the schema once: `python -m harness.cli init-db`.
# The local docker-compose Postgres is for dev only.
DATABASE_URL=postgresql://harness:harness@localhost:5432/harness

# --- Remote MCP servers (auto-connected by `harness chat`) ---
# Comma-separated "name=url".
# Auth per server: MCP_<NAME>_TOKEN (static bearer) OR MCP_<NAME>_OAUTH=1 (browser login).
# EPHEMERAL/HEADLESS: prefer MCP_<NAME>_TOKEN. The OAUTH=1 flow opens a browser
# and binds a localhost callback — it cannot run headless in a container, and it
# caches tokens under ~/.harness/mcp-auth (local disk, wiped on restart).
MCP_HTTP_SERVERS=fellow=https://fellow.app/mcp
MCP_FELLOW_OAUTH=1
# MCP_FELLOW_TOKEN=        # alternative to OAuth: a static bearer token

# --- Budgets / loop controls ---
TOKEN_BUDGET_PER_SESSION=500000   # hard ceiling; loop stops & returns partial. 0 = unlimited
RESPONSE_RESERVE_TOKENS=4000      # tokens reserved for the model's reply
MAX_STEPS=25                      # max loop iterations per turn
MAX_TOOL_CALLS_PER_STEP=8         # 0 = unlimited
MAX_TOOL_CALLS_PER_TURN=40        # 0 = unlimited
CHECKPOINT_EVERY_USER_TURNS=20    # subject classification cadence
SKILL_INDUCTION_EVERY_SESSIONS=10 # auto skill induction cadence
SKILLS_IN_PROMPT_LIMIT=30         # skills listed inline before falling back to SearchSkills
SUMMARY_KEEP_RATIO=0.10           # fraction of recent messages kept verbatim

# --- Persona & Bash tool ---
HARNESS_PERSONA_PATH=              # path to a PERSONA.md; empty => ./PERSONA.md, else default identity
BASH_TIMEOUT=60                   # per-command timeout (seconds)
BASH_MAX_OUTPUT=10000             # chars before head/tail elision
